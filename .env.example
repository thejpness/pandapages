# Panda Pages current runtime configuration
#
# Copy to the ignored .env only for local use. Every credential below is a
# documentation-only placeholder; generate independent values and never reuse
# development values in production.

# Variables consumed from the root environment by Docker Compose.

# Dedicated application-role URL. Compose maps this to DATABASE_URL in the API
# container. Percent-encode reserved characters in URL credentials.
APP_DATABASE_URL=postgres://pandapages_app:replace-with-app-password@postgres:5432/pandapages?sslmode=disable

# Dedicated migration-role URL. Compose maps this to GOOSE_DBSTRING only in the
# one-shot migration container.
MIGRATION_DATABASE_URL=postgres://pandapages_migrator:replace-with-migration-password@postgres:5432/pandapages?sslmode=disable

# Production Compose bootstrap/administrative PostgreSQL credential. Development
# Compose instead reads secrets/pg_password.txt; the names intentionally differ.
POSTGRES_PASSWORD=replace-with-postgres-bootstrap-password

# Exactly six ASCII decimal digits. This is the current shared bridge, not an
# individual account password.
PP_PASSCODE=123456

# At least 32 bytes with no leading or trailing whitespace. Generate a long,
# independent random value. Changing it invalidates every current session.
PP_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Independent server-side admin ingress credential. It is injected by Traefik
# and must never be exposed through Vite or sent by browser code.
PP_ADMIN_KEY=replace-with-independent-admin-key

# Required by production Compose. Use one CIDR or comma-separated CIDRs. The
# TEST-NET address below is a non-routable documentation placeholder.
PP_ADMIN_IPS=192.0.2.1/32

# debug, info, warn, or error. Invalid values fail API startup. The application
# default is info; development Compose may choose its own explicit default.
PP_LOG_LEVEL=info

# Direct-process settings and Compose-owned values
#
# These are supported by the named process, but root Compose does not import
# them from this file: production/dev Compose deliberately set or omit them.
#
# DATABASE_URL is the Go API's direct setting; Compose maps APP_DATABASE_URL.
# DATABASE_URL=postgres://pandapages_app:replace-with-app-password@127.0.0.1:5432/pandapages?sslmode=disable
#
# PP_COOKIE_SECURE is true only for exact value "true". Production Compose
# forces true. Local HTTP development omits it, so cookies are non-secure.
# PP_COOKIE_SECURE=false
#
# VITE_API_BASE is supported by Vite/direct frontend builds. Development
# Compose fixes it to the local host below; production builds use same-origin.
# VITE_API_BASE=http://pandapages.localhost

# Fixed container environment (not root .env inputs):
# - POSTGRES_DB=pandapages and POSTGRES_USER=pandapages.
# - development PostgreSQL reads POSTGRES_PASSWORD_FILE from the Compose secret;
#   production PostgreSQL receives POSTGRES_PASSWORD from the root input above.
# - Goose receives GOOSE_DRIVER=postgres, GOOSE_DBSTRING mapped from
#   MIGRATION_DATABASE_URL, and GOOSE_MIGRATION_DIR=/migrations.
# - the API receives PGAPPNAME=pandapages-api.
# - PP_ASSET_DIR=/data/assets remains injected by Compose, but current Go code
#   does not consume it; it is not a supported runtime setting.

# Fixed local Compose topology (not root .env inputs):
# - local application host: pandapages.localhost
# - local Traefik dashboard: http://127.0.0.1:8080
# - direct local API: http://127.0.0.1:8081
