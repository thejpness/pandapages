# Install as /etc/pandapages/postgresql-backup.env with owner root:root and mode 0600.
# Replace every REPLACE_* value before enabling any timer.

PP_BACKUP_POSTGRES_CONTAINER=pandapages-postgres-1
PP_BACKUP_DATABASE=pandapages
PP_BACKUP_DATABASE_USER=pandapages_backup
PP_BACKUP_GLOBALS_USER=pandapages

PP_BACKUP_REMOTE=s3-backups:REPLACE_PRIVATE_BUCKET/pandapages/postgresql
PP_BACKUP_RCLONE_CONFIG=/etc/pandapages/postgresql-backup-rclone.conf
PP_BACKUP_AGE_RECIPIENTS_FILE=/etc/pandapages/postgresql-backup-age-recipients.txt
PP_BACKUP_AGE_IDENTITIES_FILE=/etc/pandapages/postgresql-backup-age-identities.txt
PP_BACKUP_NOTIFY_CURL_CONFIG=/etc/pandapages/postgresql-backup-notify.curl

PP_BACKUP_STATE_DIR=/var/lib/pandapages-postgresql-backup
PP_BACKUP_LOCK_DIR=/run/pandapages-postgresql-backup
PP_BACKUP_TMP_PARENT=/var/tmp

PP_BACKUP_EXPECT_AGE_VERSION=1.3.1
PP_BACKUP_EXPECT_RCLONE_VERSION=1.74.4
PP_BACKUP_POSTGRES_IMAGE=postgres:18.1-alpine@sha256:b40d931bd0e7ce6eecc59a5a6ac3b3c04a01e559750e73e7086b6dbd7f8bf545

PP_BACKUP_RETENTION_DAILY=7
PP_BACKUP_RETENTION_WEEKLY=4
PP_BACKUP_RETENTION_MONTHLY=3
PP_BACKUP_MAX_AGE_SECONDS=129600
PP_BACKUP_RESTORE_MAX_AGE_SECONDS=777600
